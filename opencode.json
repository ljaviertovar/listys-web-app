{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"shadcn": {
			"type": "local",
			"command": ["npx", "shadcn@latest", "mcp"],
			"enabled": true
		},
		"supabase": {
			"type": "local",
			"command": ["npx", "supabase-mcp"],
			"enabled": true
		},
		"nextjs": {
			"type": "local",
			"command": ["npx", "next-devtools-mcp"],
			"enabled": true
		},
		"playwright": {
			"type": "local",
			"command": ["npx", "@playwright/mcp"],
			"enabled": true
		}
	}
}
